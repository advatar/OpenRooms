# Search API (home) environment
# Domain and base URL
PORT=3001
BASE_URL=https://openrooms.showntell.dev

# Admin and uploads
ADMIN_JWT_SECRET=change-me
TOKEN_TTL_SECONDS=28800
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_BYTES=10485760

# Database (internal to compose network)
PGHOST=postgres
PGPORT=5432
PGUSER=booking
PGPASSWORD=booking
PGDATABASE=booking

# Redis (internal to compose network)
REDIS_URL=redis://redis:6379

# Optional features
LEAD_FEE_CAP_BPS=200
BIT_TTL_SECONDS=86400
STRIPE_ENABLED=false
# STRIPE_API_KEY=
# BIT_PRIVATE_KEY_JWK=
# BIT_PUBLIC_KEY_JWK=
