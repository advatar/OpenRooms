# Copy to ops/env/prod.search-api.env and fill real secrets

PORT=3001
NODE_ENV=production

# Postgres (local on the server if provisioned with INSTALL_DB=1)
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=openrooms
PGPASSWORD=change_me_strong
PGDATABASE=openrooms

# Redis (local if provisioned with INSTALL_REDIS=1)
REDIS_URL=redis://127.0.0.1:6379

# CORS
CORS_ORIGIN=*

# Admin & uploads
# Set a strong secret to enable /v1/admin routes
ADMIN_JWT_SECRET=change_me_admin_jwt
# JWT token TTL (seconds)
TOKEN_TTL_SECONDS=28800
# Public base URL used in links returned by the API
BASE_URL=https://api.openrooms.net
# Uploads directory on server
UPLOAD_DIR=/var/openrooms/uploads
# Max upload size (bytes)
MAX_UPLOAD_BYTES=10485760

# BIT / JWT signing (Ed25519 JWK JSON)
# Provide JSON strings for JWKs. For local dev, you can reuse the same private JWK for both issue & verify.
# Example: {"kty":"OKP","crv":"Ed25519","d":"<private>","x":"<public>"}
BIT_ISSUER_DID=did:web:api.openrooms.net
BIT_PRIVATE_KEY_JWK=
BIT_PUBLIC_KEY_JWK=

# Business config
LEAD_FEE_CAP_BPS=200

# Stripe (test mode optional)
STRIPE_ENABLED=false
STRIPE_API_KEY=

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=1 minute
