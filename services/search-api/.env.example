# Postgres
PGHOST=localhost
PGPORT=5432
PGUSER=booking
PGPASSWORD=booking
PGDATABASE=booking

# Redis
REDIS_URL=redis://localhost:6379

# HTTP server
PORT=3001

# Attribution / BIT (EdDSA JWK; for dev you can generate a keypair and paste here)
# Example (PRIVATE): {"kty":"OKP","crv":"Ed25519","d":"<base64url>","x":"<base64url>"}
# Example (PUBLIC):  {"kty":"OKP","crv":"Ed25519","x":"<base64url>"}
BIT_PRIVATE_KEY_JWK=
BIT_PUBLIC_KEY_JWK=
BIT_ISSUER_DID=did:key:dev-issuer
BIT_TTL_SECONDS=86400
LEAD_FEE_CAP_BPS=200

# Payments (optional for live integrations; simulated in MVP)
STRIPE_ENABLED=false
STRIPE_API_KEY=

# Admin auth (JWT HS256)
ADMIN_JWT_SECRET=
TOKEN_TTL_SECONDS=28800

# Uploads
UPLOAD_DIR=/var/openrooms/uploads
BASE_URL=http://localhost:3001
MAX_UPLOAD_BYTES=10485760

# Optional: seed an initial admin user (used by `npm run seed`)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=changeme
