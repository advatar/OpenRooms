{
  "name": "@booking-network/search-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "seed": "tsx src/seed.ts",
    "publish:delta": "tsx src/publishDelta.ts",
    "test": "vitest run",
    "migrate:up": "node-pg-migrate up -m 'migrations/*.js' --use-glob -d DATABASE_URL",
    "migrate:down": "node-pg-migrate down -m 'migrations/*.js' --use-glob -d DATABASE_URL",
    "migrate:create": "node-pg-migrate -m migrations create"
  },
  "dependencies": {
    "@fastify/cors": "^8.4.0",
    "@fastify/multipart": "^7.7.3",
    "@fastify/rate-limit": "^8.1.1",
    "@fastify/static": "^6.12.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^1.10.2",
    "bcryptjs": "2.4.3",
    "csv-parse": "5.5.6",
    "dotenv": "16.4.5",
    "fastify": "^5.7.3",
    "jose": "5.2.4",
    "mime-types": "2.1.35",
    "pg": "8.12.0",
    "redis": "4.7.0",
    "stripe": "16.6.0",
    "uuid": "9.0.1",
    "zod": "3.23.8",
    "zod-to-json-schema": "3.23.5"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "node-pg-migrate": "7.8.0",
    "supertest": "6.3.4",
    "tsx": "4.19.0",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  }
}
