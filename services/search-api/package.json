{
  "name": "@booking-network/search-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "seed": "tsx src/seed.ts",
    "publish:delta": "tsx src/publishDelta.ts",
    "test": "vitest run",
    "migrate:up": "node-pg-migrate -m migrations -d $PGDATABASE",
    "migrate:down": "node-pg-migrate -m migrations -d $PGDATABASE",
    "migrate:create": "node-pg-migrate -m migrations create"
  },
  "dependencies": {
    "fastify": "4.28.1",
    "@fastify/cors": "10.0.1",
    "@fastify/rate-limit": "10.1.1",
    "@fastify/swagger": "9.4.0",
    "@fastify/swagger-ui": "3.0.1",
    "pg": "8.12.0",
    "redis": "4.7.0",
    "dotenv": "16.4.5",
    "jose": "5.2.4",
    "stripe": "16.6.0",
    "uuid": "9.0.1",
    "zod": "3.23.8",
    "zod-to-json-schema": "3.23.5"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "supertest": "6.3.4",
    "vitest": "1.6.0",
    "node-pg-migrate": "7.8.0",
    "tsx": "4.19.0",
    "typescript": "5.4.5"
  }
}
